Content-Type: text/css; charset="utf-8"
Content-Transfer-Encoding: 8bit
Content-Location: https://example.test/mhtml-smoke/styles.css

:root {
  color-scheme: light;
  font-family: Arial, Helvetica, sans-serif;
  background: #f5f7fa;
  color: #1f2937;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
}

.page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 32px;
}

.panel {
  width: min(640px, 100%);
  border: 1px solid #d6dee8;
  border-radius: 8px;
  background: #ffffff;
  padding: 28px;
  box-shadow: 0 12px 32px rgba(31, 41, 55, 0.08);
}

.mark {
  width: 16px;
  height: 16px;
  image-rendering: pixelated;
}

h1 {
  margin: 16px 0 8px;
  font-size: 28px;
}

p {
  line-height: 1.55;
}

button {
  appearance: none;
  border: 1px solid #2563eb;
  border-radius: 6px;
  background: #2563eb;
  color: #ffffff;
  font: inherit;
  padding: 9px 14px;
  cursor: pointer;
}

button:hover {
  background: #1d4ed8;
}

.status {
  color: #047857;
  font-weight: 700;
}

pre {
  min-height: 72px;
  margin: 18px 0 0;
  padding: 12px;
  border-radius: 6px;
  background: #111827;
  color: #d1fae5;
  overflow: auto;
}

------=_NextPart_000_0000_01DC4860.GeminiNexusSmoke
Content-Type: application/javascript; charset="utf-8"
Content-Transfer-Encoding: 8bit
Content-Location: https://example.test/mhtml-smoke/app.js

(function () {
  var status = document.getElementById("status");
  var output = document.getElementById("output");
  var button = document.getElementById("probe");

  function report() {
    var payload = {
      title: document.title,
      location: String(window.location.href),
      bodyTextLength: document.body.innerText.length,
      linkCount: document.links.length,
      imageCount: document.images.length,
      timestamp: new Date().toISOString()
    };
    output.textContent = JSON.stringify(payload, null, 2);
  }

  status.textContent = "JavaScript ran successfully inside the MHTML page.";
  button.addEventListener("click", report);
  report();
}());

