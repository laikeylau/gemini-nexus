<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Gemini Nexus MHTML Smoke Test</title>
  <link rel="stylesheet" href="https://example.test/mhtml-smoke/styles.css">
</head>
<body>
  <main class="page">
    <section class="panel">
      <img class="mark" src="https://example.test/mhtml-smoke/pixel.png" alt="">
      <h1>MHTML Smoke Test</h1>
      <p>
        This page is a local MHTML archive with embedded HTML, CSS, JavaScript,
        and image resources.
      </p>
      <p id="status" class="status">JavaScript has not run yet.</p>
      <button id="probe" type="button">Run DOM probe</button>
      <pre id="output" aria-live="polite"></pre>
    </section>
  </main>
  <script src="https://example.test/mhtml-smoke/app.js"></script>
</body>
</html>

