{
  "manifest_version": 3,
  "name": "Gemini Nexus",
  "version": "4.2.3",
  "permissions": ["sidePanel", "storage", "contextMenus", "alarms", "debugger", "downloads", "tabs"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_title": "Open Gemini Chat",
    "default_icon": "logo.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Open Gemini Nexus Sidebar"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "sandbox": {
    "pages": ["sandbox/index.html"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://chrome.google.com/webstore/*",
        "https://chromewebstore.google.com/*",
        "https://accounts.google.com/*"
      ],
      "js": ["content/main.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["logo.png", "sandbox/index.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' https://cdn.jsdelivr.net; img-src https: http: data: blob:; media-src https: http: data: blob:; object-src 'none';"
  }
}
